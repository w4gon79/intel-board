# Intel Board - Environment Variables
# Copy this file to .env and fill in your values
#
# NOTE: All API keys can also be configured in the Settings panel (API Keys section).
# Values here are used as defaults on first launch and will be auto-imported.

# === MAP ===
# No API keys needed! Map tiles use free CARTO/OpenStreetMap (dark theme).

# === NEWS (Required for Phase 1) ===
# Get a free key at https://newsapi.org/register
# Free tier: 100 requests/day (developer plan)
NEWS_API_KEY=your_newsapi_key_here

# GDELT is free and unlimited (no key needed)
# https://blog.gdeltproject.org/gdelt-doc-api/

# === AI / LLM (Required for RAG) ===
# Ollama runs locally on port 11434 by default
# Install: https://ollama.com/download
# Pull models:
#   ollama pull nomic-embed-text   (embedding model, 274 MB)
#   ollama pull qwen2.5:3b        (chat model, 1.9 GB)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Z.ai cloud API for complex analysis
# Sign up at https://z.ai
# ZAI_API_KEY=your_zai_api_key_here
# ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# === FLIGHT TRACKING (Phase 2) ===
# OpenSky Network - free flight tracking API
# Sign up at https://opensky-network.org/login/create
# Free: 4,000 requests/day (registered), 100/day (anonymous)
# OpenSky API docs: https://openskynetwork.github.io/opensky-api/
#
# OpenSky now requires OAuth2 (client_credentials flow).
# Your OPENSKY_USERNAME is used as client_id and OPENSKY_PASSWORD as client_secret.
# The app automatically fetches and refreshes access tokens (30 min lifetime).
# Leave blank for anonymous access (100 req/day limit)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# === SHIP TRACKING (Phase 2) ===
# AISStream.io - free real-time AIS data via WebSocket
# Sign up at https://aisstream.io for a free API key
# WebSocket endpoint: wss://stream.aisstream.io/v0/stream
AISSTREAM_API_KEY=your_aisstream_api_key_here

# === WEATHER (Phase 2) ===
# Open-Meteo is free, no key needed
# https://open-meteo.com/en/docs

# === GFW VESSEL PRESENCE (Phase 4I) ===
# Global Fishing Watch 4Wings API - supplements AIS for choke points
# Register at https://globalfishingwatch.org/our-apis/documentation
# Free for non-commercial use
GFW_API_TOKEN=your_gfw_api_token_here

# === ECONOMIC DATA (Phase 4) ===
# FRED API: https://fred.stlouisfed.org/docs/api/api_key.html
# Free, generous limits (120 requests/min)
# FRED_API_KEY=your_fred_api_key_here
